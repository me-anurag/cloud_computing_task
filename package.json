{
  "name": "image-upload-server",
  "version": "1.0.0",
  "description": "Scalable image upload server with NGINX load balancing and S3",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:3001": "PORT=3001 INSTANCE_ID=server-1 node src/server.js",
    "start:3002": "PORT=3002 INSTANCE_ID=server-2 node src/server.js",
    "test": "jest --forceExit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "cors": "^2.8.6",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
